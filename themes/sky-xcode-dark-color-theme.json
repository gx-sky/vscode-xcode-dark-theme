  "tokenColors": [
    {
      "name": "Default Text",
      "scope": [
        "source",
        "text.plain",
        "meta.embedded",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#DFDFE0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A98A6"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#F97BB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator.key-value",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#DFDFE0"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "meta.string"
      ],
      "settings": {
        "foreground": "#FF806C"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#FCFCFC"
      }
    },
    {
      "name": "Invalid String Escape",
      "scope": [
        "invalid.illegal.escape",
        "invalid.deprecated.escape"
      ],
      "settings": {
        "foreground": "#FD9A86",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language.number"
      ],
      "settings": {
        "foreground": "#D7C781"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.other",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FFA245",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter.function-call"
      ],
      "settings": {
        "foreground": "#FCFCFC"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.java",
        "meta.parameter",
        "meta.parameter.java",
        "entity.name.variable.parameter"
      ],
      "settings": {
        "foreground": "#DFDFE0"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Static Fields",
      "scope": [
        "variable.other.property.static",
        "variable.other.constant.property"
      ],
      "settings": {
        "foreground": "#49B0CE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "entity.name.function.method",
        "entity.name.method",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#75C2B3"
      }
    },
    {
      "name": "Static Functions",
      "scope": [
        "entity.name.function.static",
        "support.function.static"
      ],
      "settings": {
        "foreground": "#75C2B3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Type References",
      "scope": [
        "storage.type.class",
        "storage.type.interface",
        "meta.type.reference",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Type Parameters",
      "scope": [
        "entity.name.type.parameter",
        "entity.name.type.type-parameter",
        "entity.name.type.parameter.java",
        "support.type.parameter"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Predefined Symbols",
      "scope": [
        "support.variable",
        "support.function.builtin",
        "variable.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#DBB8FF"
      }
    },
    {
      "name": "Global Variables",
      "scope": [
        "variable.other.global",
        "support.variable.dom",
        "support.variable.property.dom"
      ],
      "settings": {
        "foreground": "#49B0CE"
      }
    },
    {
      "name": "Decorators and Annotations",
      "scope": [
        "meta.annotation",
        "entity.name.tag.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#F97BB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Metadata",
      "scope": [
        "meta.preprocessor",
        "entity.name.tag.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#FF78B2"
      }
    },
    {
      "name": "Namespaces and Packages",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#FFBF67"
      }
    },
    {
      "name": "Labels",
      "scope": [
        "entity.name.label",
        "meta.label"
      ],
      "settings": {
        "foreground": "#75C2B3"
      }
    },
    {
      "name": "HTML XML Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FD7CB2"
      }
    },
    {
      "name": "HTML XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute-name"
      ],
      "settings": {
        "foreground": "#FFA245"
      }
    },
    {
      "name": "HTML XML Attribute Value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html",
        "string.unquoted.html"
      ],
      "settings": {
        "foreground": "#FD8273"
      }
    },
    {
      "name": "Entity References",
      "scope": [
        "constant.character.entity",
        "constant.other.entity"
      ],
      "settings": {
        "foreground": "#D9C880"
      }
    },
    {
      "name": "Invalid Tokens",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF6B70",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#71BF47"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF6B70"
      }
    },
