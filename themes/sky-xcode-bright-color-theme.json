  "tokenColors": [
    {
      "name": "Default Text",
      "scope": [
        "source",
        "text.plain",
        "meta.embedded",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#707F8D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#AD3DA4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator.key-value",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "meta.string"
      ],
      "settings": {
        "foreground": "#C41A16"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#8B3A96"
      }
    },
    {
      "name": "Invalid String Escape",
      "scope": [
        "invalid.illegal.escape",
        "invalid.deprecated.escape"
      ],
      "settings": {
        "foreground": "#DF5C58",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language.number"
      ],
      "settings": {
        "foreground": "#1C00CF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.other",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#CC6D00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter.function-call"
      ],
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.java",
        "meta.parameter",
        "meta.parameter.java",
        "entity.name.variable.parameter"
      ],
      "settings": {
        "foreground": "#5C5C5C"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#00688B"
      }
    },
    {
      "name": "Static Fields",
      "scope": [
        "variable.other.property.static",
        "variable.other.constant.property"
      ],
      "settings": {
        "foreground": "#00688B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "entity.name.function.method",
        "entity.name.method",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#326D74"
      }
    },
    {
      "name": "Static Functions",
      "scope": [
        "entity.name.function.static",
        "support.function.static"
      ],
      "settings": {
        "foreground": "#326D74",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#00688B"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#00688B"
      }
    },
    {
      "name": "Type References",
      "scope": [
        "storage.type.class",
        "storage.type.interface",
        "meta.type.reference",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#00688B"
      }
    },
    {
      "name": "Type Parameters",
      "scope": [
        "entity.name.type.parameter",
        "entity.name.type.type-parameter",
        "entity.name.type.parameter.java",
        "support.type.parameter"
      ],
      "settings": {
        "foreground": "#00688B"
      }
    },
    {
      "name": "Predefined Symbols",
      "scope": [
        "support.variable",
        "support.function.builtin",
        "variable.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#6A3D94"
      }
    },
    {
      "name": "Global Variables",
      "scope": [
        "variable.other.global",
        "support.variable.dom",
        "support.variable.property.dom"
      ],
      "settings": {
        "foreground": "#7B3FA3"
      }
    },
    {
      "name": "Decorators and Annotations",
      "scope": [
        "meta.annotation",
        "entity.name.tag.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#AD3DA4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Metadata",
      "scope": [
        "meta.preprocessor",
        "entity.name.tag.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#C435A3"
      }
    },
    {
      "name": "Namespaces and Packages",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#CC7A00"
      }
    },
    {
      "name": "Labels",
      "scope": [
        "entity.name.label",
        "meta.label"
      ],
      "settings": {
        "foreground": "#326D74"
      }
    },
    {
      "name": "HTML XML Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C7368D"
      }
    },
    {
      "name": "HTML XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute-name"
      ],
      "settings": {
        "foreground": "#CC6D00"
      }
    },
    {
      "name": "HTML XML Attribute Value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html",
        "string.unquoted.html"
      ],
      "settings": {
        "foreground": "#C41A16"
      }
    },
    {
      "name": "Entity References",
      "scope": [
        "constant.character.entity",
        "constant.other.entity"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "Invalid Tokens",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#D73A49",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#28A745"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#D73A49"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#0066CC"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#0088AA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#0066CC"
      }
    },
    {
      "name": "Java Spring Annotations",
      "scope": [
        "storage.type.annotation.java",
        "entity.name.type.annotation.java",
        "meta.annotation.java",
        "punctuation.definition.annotation.java"
      ],
      "settings": {
        "foreground": "#AD3DA4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Java Annotation Marker",
      "scope": [
        "punctuation.definition.annotation.java"
      ],
      "settings": {
        "foreground": "#AD3DA4",
        "fontStyle": "bold"
      }
