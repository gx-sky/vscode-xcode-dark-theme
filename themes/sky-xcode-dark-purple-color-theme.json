  "tokenColors": [
    {
      "name": "Default Text",
      "scope": [
        "source",
        "text.plain",
        "meta.embedded",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#DFDFE0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A98A6"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#F97BB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Java Modifiers",
      "scope": [
        "storage.modifier.java",
        "storage.type.modifier.java"
